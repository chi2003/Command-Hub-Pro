<Window x:Class="CmdManager.Views.DetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Command Detail" Width="560" Height="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="20" FontWeight="Bold"
               Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
      <Border x:Name="CategoryBadge" CornerRadius="6" Padding="6,3">
        <TextBlock x:Name="CategoryText" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
      </Border>
      <TextBlock x:Name="AdminText" FontSize="11" Foreground="#FFFB923C"
                 VerticalAlignment="Center" Margin="8,0,0,0"/>
    </StackPanel>

    <TextBlock x:Name="DescText" Grid.Row="2" FontSize="13"
               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
               Margin="0,12,0,0" VerticalAlignment="Top"/>

    <Border Grid.Row="3" Background="#CC0C0C0C" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
      <TextBlock x:Name="CommandText" FontFamily="Consolas, Courier New" FontSize="12"
                 Foreground="#FFAAFFAA" TextWrapping="Wrap"/>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="▶ Run" Style="{StaticResource PrimaryButton}" Click="Run_Click" Margin="0,0,6,0"/>
      <Button Content="✏ Edit" Style="{StaticResource GhostButton}" Click="Edit_Click" Margin="0,0,6,0"/>
      <Button Content="🗑 Delete" Style="{StaticResource DangerButton}" Click="Delete_Click" Margin="0,0,6,0"/>
      <Button Content="Close" Style="{StaticResource GhostButton}" Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
