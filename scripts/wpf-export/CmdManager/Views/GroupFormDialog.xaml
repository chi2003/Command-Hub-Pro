<Window x:Class="CmdManager.Views.GroupFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group" Width="540" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleLabel" Grid.Row="0" FontSize="18" FontWeight="Bold"
               Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

    <StackPanel Grid.Row="1">
      <TextBlock Text="Name *" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
      <TextBox x:Name="NameBox" Style="{StaticResource SearchBox}" Margin="0,0,0,10"/>
      <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
      <TextBox x:Name="DescBox" Style="{StaticResource SearchBox}" Margin="0,0,0,12" AcceptsReturn="True" Height="50" TextWrapping="Wrap"/>
    </StackPanel>

    <TabControl Grid.Row="2" Background="Transparent" BorderBrush="{StaticResource BorderBrush}">
      <TabItem Header="Commands" Foreground="{StaticResource TextBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="CommandCheckList" Margin="8"/>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Chains" Foreground="{StaticResource TextBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="ChainCheckList" Margin="8"/>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Registry" Foreground="{StaticResource TextBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="RegistryCheckList" Margin="8"/>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click" Margin="0,0,8,0"/>
      <Button Content="Cancel" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
    </StackPanel>
  </Grid>
</Window>
