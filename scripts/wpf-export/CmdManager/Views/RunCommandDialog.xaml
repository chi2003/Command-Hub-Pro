<Window x:Class="CmdManager.Views.RunCommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Command" Width="600" Height="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Title -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
      <TextBlock x:Name="ShellText" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
    </StackPanel>

    <!-- Shell picker if "both" -->
    <StackPanel x:Name="ShellPicker" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" Visibility="Collapsed">
      <TextBlock Text="Run with:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource MutedTextBrush}"/>
      <RadioButton x:Name="UseCMD" Content="CMD" IsChecked="True" Foreground="{StaticResource TextBrush}"
                   Margin="0,0,16,0" Checked="Shell_Changed"/>
      <RadioButton x:Name="UsePS" Content="PowerShell" Foreground="{StaticResource TextBrush}"
                   Checked="Shell_Changed"/>
    </StackPanel>

    <!-- Terminal preview -->
    <Border Grid.Row="2" x:Name="TerminalBorder" CornerRadius="10" Padding="16">
      <TextBlock x:Name="TerminalText" FontFamily="Consolas, Courier New" FontSize="13"
                 TextWrapping="Wrap" VerticalAlignment="Center"/>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button x:Name="CopyBtn" Content="📋 Copy to Clipboard" Style="{StaticResource PrimaryButton}" Click="Copy_Click" Margin="0,0,8,0"/>
      <Button Content="Close" Style="{StaticResource GhostButton}" Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
