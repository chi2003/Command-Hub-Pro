<Window x:Class="CmdManager.Views.ChainFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Command Chain" Width="580" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleLabel" Grid.Row="0" FontSize="18" FontWeight="Bold"
               Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

    <StackPanel Grid.Row="1">
      <TextBlock Text="Name *" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
      <TextBox x:Name="NameBox" Style="{StaticResource SearchBox}" Margin="0,0,0,10"/>
      <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
      <TextBox x:Name="DescBox" Style="{StaticResource SearchBox}" Margin="0,0,0,10" AcceptsReturn="True" Height="50" TextWrapping="Wrap"/>
      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Category" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
          <TextBox x:Name="CategoryBox" Style="{StaticResource SearchBox}"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Shell" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
          <ComboBox x:Name="ShellBox" Style="{StaticResource StyledComboBox}">
            <ComboBoxItem Content="both"/>
            <ComboBoxItem Content="cmd"/>
            <ComboBoxItem Content="powershell"/>
          </ComboBox>
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- Steps -->
    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock Text="Steps *" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="StepsPanel"/>
      </ScrollViewer>
      <Button Grid.Row="2" Content="+ Add Step" Style="{StaticResource GhostButton}"
              HorizontalAlignment="Left" Margin="0,8,0,0" Click="AddStep_Click"/>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click" Margin="0,0,8,0"/>
      <Button Content="Cancel" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
    </StackPanel>
  </Grid>
</Window>
